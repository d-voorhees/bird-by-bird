# Environment files
.env
.env.local
.env.production
*.env
!.env.example

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Node
node_modules/
.next/
.vercel/
dist/
build/
.pnpm-store/

# Database
*.sqlite3
*.db

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# Secrets
*.pem
*.key
fly.toml.backup

# Editor config (may contain local machine paths)
.cursor/

# Developer logs (local only)
LOG/
