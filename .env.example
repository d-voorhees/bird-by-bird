# Backend environment variables
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

POSTGRES_DB=bird
POSTGRES_USER=bird
POSTGRES_PASSWORD=bird
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

JWT_SECRET=dev-jwt-secret-change-in-production

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App URL (used in verification and password-reset email links)
FRONTEND_URL=http://localhost:3000

# --- Email ---
#
# Local dev (default): emails print to the Django terminal — no inbox needed.
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Production (example: Resend — https://resend.com):
#   1. Add and verify your domain in Resend
#   2. Create an API key
#   3. Set:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_your_api_key
# DEFAULT_FROM_EMAIL=Bird by Bird <noreply@yourdomain.com>
#
# Other SMTP providers (SendGrid, Postmark, Amazon SES) use the same pattern;
# set EMAIL_HOST, EMAIL_PORT, EMAIL_USE_TLS, EMAIL_HOST_USER, EMAIL_HOST_PASSWORD
# to match their docs.

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Bird by Bird <noreply@bird.local>
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Frontend (see frontend/.env.local)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql/
